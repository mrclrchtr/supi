{
  "name": "@mrclrchtr/supi-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "SuPi (Super Pi) — The opinionated way to extend PI. Workspace root.",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "pi": {
    "extensions": [
      "./packages/supi-aliases/src/aliases.ts",
      "./packages/supi-ask-user/src/ask-user.ts",
      "./packages/supi-bash-timeout/src/index.ts",
      "./packages/supi-claude-md/src/index.ts",
      "./packages/supi-context/src/index.ts",
      "./packages/supi/src/settings.ts",
      "./packages/supi-review/src/index.ts",
      "./packages/supi-skill-shortcut/src/skill-shortcut.ts",
      "./packages/supi-lsp/src/lsp.ts",
      "./packages/supi-tree-sitter/src/tree-sitter.ts",
      "./packages/supi-cache-monitor/src/index.ts",
      "./packages/supi-code-intelligence/src/code-intelligence.ts",
      "./packages/supi-flow/src/index.ts",
      "./packages/supi-debug/src/index.ts",
      "./packages/supi-rtk/src/index.ts",
      "./packages/supi-extras/src/index.ts",
      "./packages/supi-insights/src/insights.ts"
    ],
    "prompts": [
      "./packages/supi/prompts"
    ],
    "skills": [
      "./packages/supi-flow/skills"
    ]
  },
  "scripts": {
    "biome": "biome check",
    "biome:fix": "biome check --write --error-on-warnings",
    "biome:ci": "biome ci",
    "biome:ai": "biome ci --colors=off --reporter=github",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "for p in packages/*/tsconfig.json; do tsc --noEmit -p \"$p\" || exit 1; done",
    "typecheck:tests": "for p in packages/*/__tests__/tsconfig.json; do [ -f \"$p\" ] && tsc --noEmit -p \"$p\" || exit 1; done",
    "pack:check": "pnpm --filter \"./packages/supi*\" exec pnpm pack --dry-run",
    "check": "pnpm biome",
    "check:fix": "pnpm biome:fix",
    "verify": "pnpm --filter @mrclrchtr/supi-tree-sitter check:kotlin-wasm && pnpm --filter @mrclrchtr/supi-tree-sitter check:sql-wasm && pnpm typecheck && pnpm typecheck:tests && pnpm biome:ai && pnpm test && pnpm pack:check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@mariozechner/pi-ai": "0.72.1",
    "@mariozechner/pi-coding-agent": "0.72.1",
    "@mariozechner/pi-tui": "0.72.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}

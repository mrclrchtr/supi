{
  "name": "@mrclrchtr/supi-workspace",
  "version": "1.12.0",
  "private": true,
  "description": "SuPi (Super Pi) — A curated extension stack for PI. Workspace root.",
  "packageManager": "pnpm@11.5.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "pi": {
    "extensions": [
      "./packages/supi-ask-user/src/extension.ts",
      "./packages/supi-bash-timeout/src/extension.ts",
      "./packages/supi-claude-md/src/extension.ts",
      "./packages/supi-context/src/extension.ts",
      "./packages/supi-settings/src/extension.ts",
      "./packages/supi-review/src/extension.ts",
      "./packages/supi-lsp/src/extension.ts",
      "./packages/supi-tree-sitter/src/extension.ts",
      "./packages/supi-cache/src/extension.ts",
      "./packages/supi-code-intelligence/src/extension.ts",
      "./packages/supi-debug/src/extension.ts",
      "./packages/supi-web/src/extension.ts",
      "./packages/supi-rtk/src/extension.ts",
      "./packages/supi-extras/src/extension.ts",
      "./packages/supi-insights/src/extension.ts"
    ]
  },
  "scripts": {
    "biome": "biome check",
    "biome:fix": "biome check --write --error-on-warnings",
    "biome:unsafe": "biome check --write --unsafe",
    "biome:ci": "biome ci",
    "biome:ai": "biome ci --colors=off --reporter=github",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc -b packages/*/tsconfig.json packages/*/__tests__/tsconfig.json",
    "typecheck:ai": "tsc -b --pretty false packages/*/tsconfig.json packages/*/__tests__/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ai": "vitest run --reporter=agent",
    "pack:check": "for p in packages/supi*; do [ -f \"$p/package.json\" ] || continue; node scripts/pack-staged.mjs \"$p\" --dry-run || exit 1; done",
    "pack:verify": "node scripts/pack-all.mjs",
    "check:fast": "pnpm biome",
    "check": "pnpm biome && pnpm typecheck && pnpm test",
    "check:ai": "pnpm biome:ai && pnpm typecheck:ai && pnpm test:ai",
    "check:fix": "pnpm biome:fix",
    "verify": "pnpm --filter @mrclrchtr/supi-tree-sitter check:kotlin-wasm && pnpm --filter @mrclrchtr/supi-tree-sitter check:sql-wasm && pnpm check && pnpm pack:verify",
    "verify:ai": "pnpm --filter @mrclrchtr/supi-tree-sitter check:kotlin-wasm && pnpm --filter @mrclrchtr/supi-tree-sitter check:sql-wasm && pnpm check:ai && pnpm pack:verify"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@earendil-works/pi-ai": "0.75.4",
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@earendil-works/pi-tui": "0.75.4",
    "@pnpm/exportable-manifest": "1000.4.2",
    "@types/node": "25.9.2",
    "@mrclrchtr/supi-test-utils": "workspace:*",
    "clipboardy": "5.3.1",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-typescript": "0.23.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "web-tree-sitter": "0.26.9"
  }
}

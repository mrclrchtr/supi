{
  "name": "@mrclrchtr/supi-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "SuPi (Super Pi) — The opinionated way to extend PI. Workspace root.",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "pi": {
    "extensions": [
      "./packages/supi-aliases/aliases.ts",
      "./packages/supi-ask-user/ask-user.ts",
      "./packages/supi-bash-timeout/index.ts",
      "./packages/supi-claude-md/index.ts",
      "./packages/supi/settings.ts",
      "./packages/supi-skill-shortcut/skill-shortcut.ts",
      "./packages/supi-lsp/lsp.ts"
    ],
    "prompts": [
      "./packages/supi/prompts"
    ],
    "skills": [
      "./packages/supi/skills"
    ]
  },
  "scripts": {
    "biome": "biome check",
    "biome:fix": "biome check --write --error-on-warnings",
    "biome:ci": "biome ci",
    "biome:ai": "biome ci --colors=off --reporter=github",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "for p in packages/*/tsconfig.json; do tsc --noEmit -p \"$p\" || exit 1; done",
    "typecheck:tests": "for p in packages/*/__tests__/tsconfig.json; do [ -f \"$p\" ] && tsc --noEmit -p \"$p\" || exit 1; done",
    "pack:check": "pnpm --filter @mrclrchtr/supi exec pnpm pack --dry-run",
    "check": "pnpm biome",
    "check:fix": "pnpm biome:fix",
    "verify": "pnpm typecheck && pnpm typecheck:tests && pnpm biome:ai && pnpm test && pnpm pack:check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "~0.69.0",
    "@mariozechner/pi-tui": "~0.69.0",
    "typebox": ">=1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}

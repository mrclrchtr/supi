{
  "name": "@mrclrchtr/supi-review",
  "version": "1.6.0",
  "description": "SuPi Review extension — structured code review via /supi-review command",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "4.1.7"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json"
  }
}

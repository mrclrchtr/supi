{
  "name": "@mrclrchtr/supi",
  "version": "1.2.0",
  "description": "SuPi (Super Pi) \u2014 A curated extension stack for PI. Meta-package bundling the full SuPi collection.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@mrclrchtr/supi-ask-user": "workspace:*",
    "@mrclrchtr/supi-bash-timeout": "workspace:*",
    "@mrclrchtr/supi-claude-md": "workspace:*",
    "@mrclrchtr/supi-core": "workspace:*",
    "@mrclrchtr/supi-debug": "workspace:*",
    "@mrclrchtr/supi-lsp": "workspace:*",
    "@mrclrchtr/supi-context": "workspace:*",
    "@mrclrchtr/supi-tree-sitter": "workspace:*",
    "@mrclrchtr/supi-code-intelligence": "workspace:*",
    "@mrclrchtr/supi-extras": "workspace:*"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-ask-user",
    "@mrclrchtr/supi-bash-timeout",
    "@mrclrchtr/supi-claude-md",
    "@mrclrchtr/supi-core",
    "@mrclrchtr/supi-debug",
    "@mrclrchtr/supi-lsp",
    "@mrclrchtr/supi-context",
    "@mrclrchtr/supi-tree-sitter",
    "@mrclrchtr/supi-code-intelligence",
    "@mrclrchtr/supi-extras"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "4.1.6"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json"
  }
}

{
  "name": "@mrclrchtr/supi",
  "version": "0.1.0",
  "description": "SuPi (Super Pi) \u2014 The opinionated way to extend PI. Meta-package bundling the full SuPi extension stack.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@mrclrchtr/supi-aliases": "workspace:*",
    "@mrclrchtr/supi-ask-user": "workspace:*",
    "@mrclrchtr/supi-bash-timeout": "workspace:*",
    "@mrclrchtr/supi-claude-md": "workspace:*",
    "@mrclrchtr/supi-cache-monitor": "workspace:*",
    "@mrclrchtr/supi-core": "workspace:*",
    "@mrclrchtr/supi-debug": "workspace:*",
    "@mrclrchtr/supi-lsp": "workspace:*",
    "@mrclrchtr/supi-skill-shortcut": "workspace:*",
    "@mrclrchtr/supi-context": "workspace:*",
    "@mrclrchtr/supi-review": "workspace:*",
    "@mrclrchtr/supi-rtk": "workspace:*",
    "@mrclrchtr/supi-tree-sitter": "workspace:*",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-typescript": "^0.23.0",
    "web-tree-sitter": "^0.26.8",
    "@mrclrchtr/supi-code-intelligence": "workspace:*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  },
  "pi": {
    "extensions": [
      "./src/aliases.ts",
      "./src/ask-user.ts",
      "./src/bash-timeout.ts",
      "./src/claude-md.ts",
      "./src/resources.ts",
      "./src/settings.ts",
      "./src/skill-shortcut.ts",
      "./src/lsp.ts",
      "./src/review.ts",
      "./src/debug.ts",
      "./src/rtk.ts",
      "./src/context.ts",
      "./src/tree-sitter.ts",
      "./src/cache-monitor.ts",
      "./src/code-intelligence.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  }
}

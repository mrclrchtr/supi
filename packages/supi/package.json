{
  "name": "@mrclrchtr/supi",
  "version": "0.1.0",
  "description": "SuPi (Super Pi) — The opinionated way to extend PI. Meta-package bundling the full SuPi extension stack.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "*.ts",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@mrclrchtr/supi-aliases": "workspace:*",
    "@mrclrchtr/supi-ask-user": "workspace:*",
    "@mrclrchtr/supi-bash-timeout": "workspace:*",
    "@mrclrchtr/supi-claude-md": "workspace:*",
    "@mrclrchtr/supi-core": "workspace:*",
    "@mrclrchtr/supi-lsp": "workspace:*",
    "@mrclrchtr/supi-skill-shortcut": "workspace:*",
    "@mrclrchtr/supi-tree-sitter": "workspace:*",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-typescript": "^0.23.0",
    "web-tree-sitter": "^0.26.8"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "~0.69.0"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  },
  "pi": {
    "extensions": [
      "./aliases.ts",
      "./ask-user.ts",
      "./bash-timeout.ts",
      "./claude-md.ts",
      "./resources.ts",
      "./settings.ts",
      "./skill-shortcut.ts",
      "./lsp.ts",
      "./tree-sitter.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  }
}

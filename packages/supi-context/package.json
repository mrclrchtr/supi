{
  "name": "@mrclrchtr/supi-context",
  "version": "0.1.0",
  "description": "SuPi Context extension — detailed context usage report via /supi-context command",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "*.ts",
    "*.json",
    "*.md",
    "!__tests__"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "main": "index.ts"
}

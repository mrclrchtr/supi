{
  "name": "@mrclrchtr/supi-context",
  "version": "1.16.1",
  "description": "SuPi Context extension — detailed context usage report via /supi-context command",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git",
    "directory": "packages/supi-context"
  },
  "homepage": "https://github.com/mrclrchtr/supi/tree/main/packages/supi-context#readme",
  "bugs": {
    "url": "https://github.com/mrclrchtr/supi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "context-window",
    "token-usage",
    "usage-report",
    "diagnostics"
  ],
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*",
    "typebox": "*"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-core"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "4.1.9",
    "@mrclrchtr/supi-test-utils": "workspace:*"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "image": "https://raw.githubusercontent.com/mrclrchtr/supi/main/screenshots/supi-context.png"
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json"
  }
}

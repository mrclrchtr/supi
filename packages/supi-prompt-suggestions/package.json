{
  "name": "@mrclrchtr/supi-prompt-suggestions",
  "version": "2.0.3",
  "description": "Advisory ghost-text prompt suggestions for the pi coding agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git",
    "directory": "packages/supi-prompt-suggestions"
  },
  "homepage": "https://github.com/mrclrchtr/supi/tree/main/packages/supi-prompt-suggestions#readme",
  "bugs": {
    "url": "https://github.com/mrclrchtr/supi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "prompt-suggestions",
    "prompt",
    "suggestions",
    "ghost-text"
  ],
  "type": "module",
  "files": [
    "src/**/*.ts",
    "!__tests__"
  ],
  "exports": {
    "./extension": {
      "types": "./src/extension.ts",
      "import": "./src/extension.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "import": "./src/api.ts"
    }
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@mrclrchtr/supi-core": "workspace:*"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-core"
  ],
  "devDependencies": {
    "@types/node": "25.9.4",
    "vitest": "4.1.9"
  }
}

{
  "name": "@mrclrchtr/supi-lsp",
  "version": "1.0.0",
  "description": "SuPi LSP extension — Language Server Protocol integration for pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts",
    "src/**/*.json",
    "!__tests__"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "0.2.0"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-core"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "vitest": "^4.1.4",
    "@mrclrchtr/supi-test-utils": "workspace:*"
  },
  "pi": {
    "extensions": [
      "./src/lsp.ts"
    ]
  },
  "main": "src/index.ts"
}

{
  "name": "@mrclrchtr/supi-lsp",
  "version": "2.0.4",
  "description": "SuPi LSP extension — Language Server Protocol integration for pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git",
    "directory": "packages/supi-lsp"
  },
  "homepage": "https://github.com/mrclrchtr/supi/tree/main/packages/supi-lsp#readme",
  "bugs": {
    "url": "https://github.com/mrclrchtr/supi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "lsp",
    "language-server",
    "go-to-definition",

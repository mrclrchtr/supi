{
  "name": "@mrclrchtr/supi-lsp",
  "version": "0.1.0",
  "description": "SuPi LSP extension — Language Server Protocol integration for pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "*.ts",
    "*.json",
    "resources",
    "!__tests__"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  },
  "pi": {
    "extensions": [
      "./lsp.ts"
    ],
    "skills": [
      "./resources"
    ]
  }
}

{
  "name": "@mrclrchtr/supi-lsp",
  "version": "1.14.1",
  "description": "SuPi LSP extension — Language Server Protocol integration for pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts",
    "src/**/*.json",
    "!__tests__"
  ],
  "dependencies": {
    "@mrclrchtr/supi-code-runtime": "workspace:*",
    "@mrclrchtr/supi-core": "workspace:*",
    "ignore": "^7.0.5",
    "typescript": "6.0.3",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-code-runtime",
    "@mrclrchtr/supi-core",
    "ignore",
    "typescript",
    "vscode-jsonrpc",
    "vscode-languageserver-protocol",
    "vscode-languageserver-types"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mrclrchtr/supi-code-intelligence": "workspace:*",
    "@mrclrchtr/supi-test-utils": "workspace:*",
    "vitest": "4.1.9"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "image": "https://raw.githubusercontent.com/mrclrchtr/supi/main/packages/supi-lsp/assets/logo.png"
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json",
    "./provider/lsp-semantic-provider": "./src/provider/lsp-semantic-provider.ts"
  }
}

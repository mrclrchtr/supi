{
  "name": "@mrclrchtr/supi-tree-sitter",
  "version": "1.16.1",
  "description": "SuPi Tree-sitter extension — structural AST analysis for pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git",
    "directory": "packages/supi-tree-sitter"
  },
  "homepage": "https://github.com/mrclrchtr/supi/tree/main/packages/supi-tree-sitter#readme",
  "bugs": {
    "url": "https://github.com/mrclrchtr/supi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "tree-sitter",
    "ast",
    "syntax-tree",
    "code-navigation",
    "structural-search"
  ],
  "type": "module",
  "files": [
    "src/**/*.ts",
    "src/**/*.json",
    "resources",
    "scripts/*.mjs",
    "!__tests__"
  ],
  "scripts": {
    "vendor:wasm": "node scripts/vendor-wasm.mjs",
    "check:wasm": "node scripts/vendor-wasm.mjs --check",
    "generate:kotlin-wasm": "node scripts/generate-kotlin-wasm.mjs",
    "check:kotlin-wasm": "node scripts/generate-kotlin-wasm.mjs --check",
    "generate:sql-wasm": "node scripts/generate-sql-wasm.mjs",
    "check:sql-wasm": "node scripts/generate-sql-wasm.mjs --check"
  },
  "dependencies": {
    "@mrclrchtr/supi-code-runtime": "workspace:*",
    "@mrclrchtr/supi-core": "workspace:*",
    "web-tree-sitter": "^0.26.8"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-code-runtime",
    "@mrclrchtr/supi-core",
    "web-tree-sitter"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@davisvaughan/tree-sitter-r": "1.3.0",
    "@derekstride/tree-sitter-sql": "0.3.11",
    "@types/node": "25.9.4",
    "tree-sitter-bash": "0.25.1",
    "tree-sitter-c": "0.24.1",
    "tree-sitter-cli": "0.26.9",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-html": "0.23.2",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter": "0.25.0",
    "tree-sitter-kotlin": "0.3.8",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "0.23.2",
    "vitest": "4.1.9",
    "@mrclrchtr/supi-test-utils": "workspace:*"
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./package.json": "./package.json",
    "./provider/tree-sitter-provider": "./src/provider/tree-sitter-provider.ts"
  }
}

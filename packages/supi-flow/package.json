{
  "name": "@mrclrchtr/supi-flow",
  "version": "0.1.0",
  "description": "SuPi flow extension — lightweight spec-driven workflow with brainstorm → plan → apply → archive",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },

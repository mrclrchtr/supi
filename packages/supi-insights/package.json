{
  "name": "@mrclrchtr/supi-insights",
  "version": "2.0.4",
  "description": "SuPi Insights extension — generate usage reports analyzing your PI sessions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git",
    "directory": "packages/supi-insights"
  },
  "homepage": "https://github.com/mrclrchtr/supi/tree/main/packages/supi-insights#readme",
  "bugs": {
    "url": "https://github.com/mrclrchtr/supi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "analytics",
    "session-analysis",
    "usage-report",
    "html-report"
  ],
  "type": "module",
  "files": [
    "src/**/*.ts",
    "!__tests__/**",
    "src/report.css",
    "src/report.js",
    "README.md"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*",
    "diff": "^9.0.0"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-core"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "vitest": "4.1.9"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "image": "https://raw.githubusercontent.com/mrclrchtr/supi/main/screenshots/supi-insights-1.png"
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json"
  }
}

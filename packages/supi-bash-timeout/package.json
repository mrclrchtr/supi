{
  "name": "@mrclrchtr/supi-bash-timeout",
  "version": "0.1.0",
  "description": "SuPi bash-timeout extension — injects default timeout on bash tool calls",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "*.ts",
    "!__tests__"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^4.1.4"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}

{
  "name": "@mrclrchtr/supi-ask-user",
  "version": "1.1.1",
  "description": "SuPi ask-user extension — rich questionnaire UI for structured agent-user decisions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",

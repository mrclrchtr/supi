  "main": "src/index.ts",
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-core"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "vitest": "4.1.6"
  },
  "pi": {
    "extensions": [
      "./src/ask-user.ts"
    ]
  }
}

{
  "name": "@mrclrchtr/supi-rtk",
  "version": "0.1.0",
  "description": "SuPi RTK extension — transparent bash command rewriting via RTK for token savings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {

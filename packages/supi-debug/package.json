{
  "name": "@mrclrchtr/supi-debug",
  "version": "1.3.0",
  "description": "SuPi Debug extension — shared debug event inspection for SuPi extensions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-core"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "4.1.6",
    "@mrclrchtr/supi-test-utils": "workspace:*"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts",
      "node_modules/@mrclrchtr/supi-core/src/extension.ts"
    ]
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json"
  }
}

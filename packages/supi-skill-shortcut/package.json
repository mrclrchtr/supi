{
  "name": "@mrclrchtr/supi-skill-shortcut",
  "version": "0.1.0",
  "description": "SuPi skill-shortcut extension — type $skill-name as shorthand for /skill:skill-name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts"
  ],
  "main": "src/index.ts",
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./src/skill-shortcut.ts"
    ]
  }
}

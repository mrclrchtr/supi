{
  "name": "@mrclrchtr/supi-web",
  "version": "2.0.1",
  "description": "SuPi Web extension — fetch web pages as clean Markdown (web_fetch_md) and library docs via Context7 (web_docs_search, web_docs_fetch)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git",
    "directory": "packages/supi-web"
  },
  "homepage": "https://github.com/mrclrchtr/supi/tree/main/packages/supi-web#readme",
  "bugs": {
    "url": "https://github.com/mrclrchtr/supi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "web-fetch",
    "markdown",
    "context7",
    "documentation",
    "readability"
  ],
  "type": "module",
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*",
    "jsdom": "^29.0.0",
    "@mozilla/readability": "^0.6.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-core"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "4.1.9",
    "@types/jsdom": "28.0.3",
    "@types/turndown": "5.0.6",
    "@mrclrchtr/supi-test-utils": "workspace:*"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "image": "https://raw.githubusercontent.com/mrclrchtr/supi/main/screenshots/supi-web.png"
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json"
  }
}

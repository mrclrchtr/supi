{
  "name": "@mrclrchtr/supi-web",
  "version": "1.2.0",
  "description": "SuPi Web extension — fetch web pages as clean Markdown (web_fetch_md) and library docs via Context7 (web_docs_search, web_docs_fetch)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*",
    "@upstash/context7-sdk": "^0.3.0",
    "jsdom": "^29.0.0",
    "@mozilla/readability": "^0.6.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-core"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "4.1.6",
    "@types/jsdom": "28.0.3",
    "@types/turndown": "5.0.6",
    "@mrclrchtr/supi-test-utils": "workspace:*"
  },
  "pi": {
    "extensions": [
      "./src/web.ts",
      "./src/docs.ts"
    ]
  },
  "main": "src/index.ts"
}

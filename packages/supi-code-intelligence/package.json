    "@mrclrchtr/supi-lsp": "workspace:*",
    "@mrclrchtr/supi-tree-sitter": "workspace:*",
    "ts-pattern": "^5.9.0"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-code-runtime",
    "@mrclrchtr/supi-core",
    "@mrclrchtr/supi-lsp",

{
  "name": "@mrclrchtr/supi-code-intelligence",
  "version": "1.11.3",
  "description": "SuPi Code Intelligence extension — architecture briefs, caller/callee analysis, impact assessment, and pattern search for pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "src/**/*.ts"
  ],
  "dependencies": {
    "@mrclrchtr/supi-code-runtime": "workspace:*",
    "@mrclrchtr/supi-core": "workspace:*",
    "@mrclrchtr/supi-lsp": "workspace:*",
    "@mrclrchtr/supi-tree-sitter": "workspace:*"
  },
  "bundledDependencies": [
    "@mrclrchtr/supi-code-runtime",
    "@mrclrchtr/supi-core",
    "@mrclrchtr/supi-lsp",
    "@mrclrchtr/supi-tree-sitter"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "vitest": "4.1.8",
    "@mrclrchtr/supi-test-utils": "workspace:*"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts",
      "node_modules/@mrclrchtr/supi-lsp/src/extension.ts",
      "node_modules/@mrclrchtr/supi-tree-sitter/src/extension.ts"
    ],
    "image": "https://raw.githubusercontent.com/mrclrchtr/supi/main/packages/supi-code-intelligence/assets/logo.png"
  },
  "main": "src/api.ts",
  "exports": {
    "./api": "./src/api.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json"
  }
}

{
  "name": "@mrclrchtr/supi-claude-md",
  "version": "0.1.0",
  "description": "SuPi claude-md extension — automatic subdirectory context injection and root context refresh for pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrclrchtr/supi.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "files": [
    "*.ts",
    "resources",
    "!__tests__"
  ],
  "dependencies": {
    "@mrclrchtr/supi-core": "workspace:*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "~0.69.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^4.1.4"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./resources"
    ]
  }
}
